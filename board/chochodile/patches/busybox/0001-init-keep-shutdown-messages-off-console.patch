From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Francois <francois@localhost>
Date: Sun, 31 May 2026 17:14:00 +0200
Subject: [PATCH] init: keep shutdown messages off console

The Chochodile image is intentionally quiet and uses the console for the
foreground application. Keep BusyBox init's shutdown progress messages in
syslog only so poweroff does not print system chatter over the UI.

Signed-off-by: Francois <francois@localhost>
---
 init/init.c | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/init/init.c b/init/init.c
index 7a2a3b4..7c1d9e0 100644
--- a/init/init.c
+++ b/init/init.c
@@ -762,16 +762,16 @@ static void run_shutdown_and_kill_processes(void)
 	 * shut things down gracefully... */
 	run_actions(SHUTDOWN);
 
-	message(L_CONSOLE | L_LOG, "The system is going down NOW!");
+	message(L_LOG, "The system is going down NOW!");
 
 	/* Send signals to every process _except_ pid 1 */
 	kill(-1, SIGTERM);
-	message(L_CONSOLE, "Sent SIG%s to all processes", "TERM");
+	message(L_LOG, "Sent SIG%s to all processes", "TERM");
 	sync();
 	sleep1();
 
 	kill(-1, SIGKILL);
-	message(L_CONSOLE, "Sent SIG%s to all processes", "KILL");
+	message(L_LOG, "Sent SIG%s to all processes", "KILL");
 	sync();
 	/*sleep1(); - callers take care about making a pause */
 }
@@ -832,7 +832,7 @@ static void halt_reboot_pwoff(int sig)
 		m = "poweroff";
 		rb = RB_POWER_OFF;
 	}
-	message(L_CONSOLE, "Requesting system %s", m);
+	message(L_LOG, "Requesting system %s", m);
 	pause_and_low_level_reboot(rb);
 	/* not reached */
 }
