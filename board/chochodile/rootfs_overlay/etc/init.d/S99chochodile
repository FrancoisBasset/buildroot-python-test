#!/bin/sh

case "$1" in
	start)
		# The app is started by init scripts (not an interactive shell),
		# so set locale here to guarantee UTF-8 output/input.
		export LANG=C
		export LC_ALL=C
		export PYTHONUTF8=1
		export PYTHONIOENCODING=utf-8
		# Launch on the system console so output is visible.
		# Keep it in background to avoid blocking boot.
		/usr/bin/python3 /usr/bin/chochodile.py </dev/console >/dev/console 2>&1 &
		;;
esac

exit 0
